# Copy to .env and fill in. .env is gitignored.

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- SQL Server ----
# Adjust to your local SQL Server instance. The API expects the Gold schema
# (from sql/gold/) and the api_audit schema (from scripts/setup_audit_schema.sql)
# in the same database.
SQL_SERVER=Ryzen7PC\SQLEXPRESS
SQL_DATABASE=pymeconta_local
SQL_USER=sa
SQL_PASSWORD=replace-me
SQL_DRIVER={ODBC Driver 17 for SQL Server}
SQL_POOL_SIZE=10

# ---- JWT ----
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# Set true in prod to disable mock header fallback for /chat auth.
AUTH_REQUIRE_JWT=false

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=false

# ---- Rate limiting (sliding window in-memory; Redis in v0.2) ----
RATE_LIMIT_TENANT_HOUR=100
RATE_LIMIT_USER_HOUR=30
RATE_LIMIT_TOKENS_DAY=1000000
